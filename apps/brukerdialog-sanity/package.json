{
  "name": "test-sanity",
  "private": true,
  "version": "1.0.0",
  "main": "package.json",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "build": "sanity build",
    "generer-typer:meld-inn-endring": "sanity schema extract --workspace meld-inn-endring && sanity typegen generate && mv sanity.types.ts ../selvbetjening-ui/src/meldInnEndring && rm -rf schema.json",
    "generer-typer:felleskomponenter": "sanity schema extract --workspace felleskomponenter && sanity typegen generate && mv sanity.types.ts ../selvbetjening-ui/src/common && rm -rf schema.json",
    "deploy": "sanity deploy",
    "deploy-graphql": "sanity graphql deploy",
    "export-sanity-innhold": "yarn tsx exportSanityInnhold.ts",
    "lint": "eslint"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "@sanity/export": "^6.0.6",
    "@sanity/vision": "^5.19.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanity": "^5.19.0",
    "styled-components": "^6.3.12",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/react": "^19.2.14",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "prettier": "^3.8.1"
  },
  "prettier": {
    "trailingComma": "es5",
    "printWidth": 120,
    "tabWidth": 4,
    "semi": false,
    "singleQuote": true,
    "bracketSpacing": true
  },
  "lint-staged": {
        "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
            "eslint"
        ]
    },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
