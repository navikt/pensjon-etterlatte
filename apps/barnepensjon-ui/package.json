{
    "name": "barnepensjon-ui-client",
    "version": "0.1.0",
    "private": true,
    "homepage": "/barnepensjon/soknad",
    "type": "module",
    "dependencies": {
        "@navikt/ds-css": "^8.7.0",
        "@navikt/aksel-icons": "^8.7.0",
        "@navikt/ds-react": "^8.7.0",
        "@navikt/fnrvalidator": "^2.2.1",
        "@navikt/nav-dekoratoren-moduler": "^3.6.2",
        "@vitejs/plugin-react-swc": "^4.2.3",
        "@vitest/coverage-v8": "^4.0.18",
        "axios": "1.13.5",
        "axios-retry": "^4.5.0",
        "bowser": "^2.14.1",
        "date-fns": "^4.1.0",
        "error-stack-parser": "^2.1.4",
        "ibantools": "^4.5.1",
        "lodash": "^4.17.21",
        "nav-faker": "^3.2.4",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-hook-form": "^7.71.2",
        "react-router-dom": "^7.13.0",
        "typescript": "^5.9.3",
        "uuid": "^13.0.0",
        "vite": "^7.3.2",
        "vite-plugin-svgr": "^4.5.0",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.18",
        "web-vitals": "^5.1.0"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@biomejs/biome": "2.4.4",
        "@testing-library/react": "^16.3.2",
        "@testing-library/react-hooks": "^8.0.1",
        "@testing-library/user-event": "^14.6.1",
        "@types/lodash": "^4.17.24",
        "@types/node": "^25.3.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-router-dom": "^5.3.3",
        "@types/uuid": "^11.0.0",
        "concurrently": "^9.2.1",
        "cypress": "^15.10.0",
        "globals": "^17.3.0",
        "husky": "~9.1.7",
        "jsdom": "^28.1.0"
    },
    "scripts": {
        "dev": "concurrently \"yarn start\" \"yarn start:node\"",
        "start": "vite --base /barnepensjon/soknad",
        "start:node": "cd ../etterlatte-node-server && yarn start:bp",
        "build": "tsc && yarn biome lint --no-errors-on-unmatched && vite build --outDir build --base /barnepensjon/soknad",
        "preview": "vite preview --port 5173",
        "test": "vitest",
        "lint": "yarn biome check --no-errors-on-unmatched",
        "cy:test": "TZ=Europe/Oslo cypress run",
        "cy:open": "TZ=Europe/Oslo cypress open"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "resolutions": {
        "**/braces": "3.0.3",
        "**/ws": "7.5.10"
    },
    "lint-staged": {
        "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
            "biome check --write --no-errors-on-unmatched"
        ]
    }
}
